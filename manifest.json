{
  "manifest_version": 3,
  "name": "Camouflage Academic Reader",
  "version": "2.1.0",
  "description": "Distraction-free reader mode that reformats web pages into an academic paper layout.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Camouflage Academic Reader",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/kuromoji.js", "content.js"],
      "css": ["academic.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-academic-mode": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle Academic Mode"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/kuromoji.js", "lib/dict/*.dat.gz", "academic.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
